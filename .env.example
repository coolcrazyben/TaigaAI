# ──────────────────────────────────────────────────────────────
# Prince Oil Analytics Platform — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git.
# ──────────────────────────────────────────────────────────────

# ── Supabase (required for AI chat and ingestion) ─────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shorthand aliases used by ingestion/index.js in CI
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# ── Anthropic Claude (required for AI chat) ───────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Taiga Data login (required for scraper) ───────────────────
TAIGA_EMAIL=your-email@example.com
TAIGA_PASSWORD=your-password
TAIGA_BASE_URL=https://app.taigadata.com
TAIGA_LOGIN_URL=https://app.taigadata.com/login

# Optional: direct URL to Store Performance report page
TAIGA_REPORT_URL=https://app.taigadata.com/store-performance

# ── Scraper options ───────────────────────────────────────────
DOWNLOAD_DIR=downloads
LOG_FILE=scraper.log
# Path to save/reuse browser session cookies (speeds up repeated runs)
TAIGA_STORAGE_STATE=data/taiga-storage-state.json

# ── CSS Selector overrides (update if scraper can't find elements) ──
# SEL_EMAIL=input[type="email"]
# SEL_PASSWORD=input[type="password"]
# SEL_SUBMIT=button[type="submit"]
# SEL_STORE_DROPDOWN=[data-testid="store-select"]
# SEL_STORE_OPTION=[role="option"]
# SEL_DATE_PICKER=[aria-label*="date" i]
# SEL_EXPORT=button:has-text("Export")
# SEL_TX_SUMMARY_NAV=a:has-text("Transaction Summary")
# SEL_MERCH_NAV=a:has-text("Merchandise")
# SEL_BRAND_GROUP=button:has-text("Brand")
# SEL_PRODUCT_GROUP=button:has-text("Product")

# ── Discovery tool (optional) ─────────────────────────────────
TAIGA_DISCOVERY_OUTPUT=data/taiga-network-discovery.json
